# Google Gemini API Key and Model configuration
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Email Configuration
# Set to true to enable sending emails, false to only log in console
SEND_EMAIL=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Database Configuration (if using PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/terafac

# Proxy Configuration (optional, for YouTube scraping)
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password
